# Copy to .env and fill in values. .env is gitignored — never commit it.

# --- Postgres credentials ---
POSTGRES_USER=parfume
POSTGRES_PASSWORD=parfume
POSTGRES_DB=parfume

# Full async SQLAlchemy URL the app connects with (host "db" = compose service).
DATABASE_URL=postgresql+asyncpg://parfume:parfume@db:5432/parfume

# --- auth ---
# Generate a strong random value, e.g.  openssl rand -hex 32
JWT_SECRET=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=720

# --- first admin (seeded on startup if no admin exists) ---
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin

# --- scheduling / timezone ---
APP_TIMEZONE=Asia/Tashkent

# --- SMS ---
# Provider: "console" (logs only, no real SMS) or "eskiz".
SMS_PROVIDER=console
SMS_POLL_SECONDS=30
SMS_MAX_CONCURRENCY=5
# Eskiz.uz credentials (only needed when SMS_PROVIDER=eskiz). If missing, the app
# falls back to the console provider.
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_BASE_URL=https://notify.eskiz.uz/api
ESKIZ_FROM=4546
